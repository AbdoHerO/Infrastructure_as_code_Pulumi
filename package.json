{
  "name": "cloudforge",
  "version": "0.2.24",
  "private": true,
  "description": "CloudForge — Modern Infrastructure Platform. Provision. Configure. Deploy. Manage.",
  "author": "CloudForge",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "type": "module",
  "scripts": {
    "build": "corepack pnpm -r --if-present build",
    "dev": "turbo run dev",
    "desktop": "corepack pnpm --filter @cloudforge/desktop dev",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "lint": "corepack pnpm -r --if-present lint",
    "lint:fix": "corepack pnpm -r --if-present lint -- --fix",
    "test": "corepack pnpm -r --if-present test",
    "test:coverage": "vitest run --coverage",
    "release:version": "node scripts/set-release-version.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "clean": "corepack pnpm -r --if-present clean && rimraf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.16.11",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.3",
    "@vitest/coverage-v8": "^2.1.3"
  }
}
