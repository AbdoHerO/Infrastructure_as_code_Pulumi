{
  "name": "@cloudforge/service-providers",
  "version": "0.1.0",
  "private": true,
  "description": "Adapters for non-infrastructure service providers such as Cloudflare.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@cloudforge/core": "workspace:*",
    "@cloudforge/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.3",
    "rimraf": "^6.0.1"
  }
}
