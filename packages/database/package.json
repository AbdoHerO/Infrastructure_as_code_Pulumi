{
  "name": "@cloudforge/database",
  "version": "0.1.0",
  "private": true,
  "description": "CloudForge persistence — Prisma client, SQLite schema and repository implementations.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:bootstrap-sql": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/bootstrap.sql",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@cloudforge/core": "workspace:*",
    "@cloudforge/shared": "workspace:*",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
