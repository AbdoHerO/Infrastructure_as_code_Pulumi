{
  "name": "@cloudforge/providers",
  "version": "0.1.0",
  "private": true,
  "description": "CloudForge Oracle and AWS adapters implementing the provider-independent CloudProvider contract.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1086.0",
    "@aws-sdk/client-sts": "^3.1086.0",
    "@cloudforge/core": "workspace:*",
    "@cloudforge/shared": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
