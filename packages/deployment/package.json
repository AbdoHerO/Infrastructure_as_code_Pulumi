{
  "name": "@cloudforge/deployment",
  "version": "0.1.0",
  "private": true,
  "description": "CloudForge deployment engine — runs deployment steps over SSH (implements the Deployer port).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@cloudforge/core": "workspace:*",
    "@cloudforge/shared": "workspace:*",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/ssh2": "^1.15.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3",
    "yaml": "2.8.1"
  }
}
