{
  "name": "@cloudforge/desktop",
  "version": "0.2.5",
  "private": true,
  "description": "CloudForge desktop application (Electron + React).",
  "main": "./out/main/index.js",
  "author": "CloudForge",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "package": "electron-vite build && electron-builder",
    "package:dir": "electron-vite build && electron-builder --dir",
    "clean": "rimraf out dist release *.tsbuildinfo"
  },
  "dependencies": {
    "@cloudforge/core": "workspace:*",
    "@cloudforge/database": "workspace:*",
    "@cloudforge/deployment": "workspace:*",
    "@cloudforge/providers": "workspace:*",
    "@cloudforge/pulumi": "workspace:*",
    "@cloudforge/shared": "workspace:*",
    "@cloudforge/ui": "workspace:*",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.22.0",
    "@pulumi/oci": "^4.19.0",
    "@pulumi/pulumi": "^3.136.0",
    "@tanstack/react-query": "^5.59.13",
    "electron-updater": "^6.8.9",
    "framer-motion": "^11.11.9",
    "lucide-react": "^0.454.0",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-router-dom": "^6.27.0",
    "ssh2": "^1.16.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "43.1.0",
    "electron-builder": "26.9.1",
    "electron-builder-squirrel-windows": "26.9.1",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vitest": "^2.1.3"
  }
}
